generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  status           OrderStatus    @default(PENDING)
  tier             ServiceTier
  supportTier      SupportTier
  deliveryMethod   DeliveryMethod
  hddRemoval       HddRemovalOption?
  computerMake     String?
  computerModel    String?
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  address          String?
  preferredDate    DateTime?
  notes            String?
  stripeSessionId  String?
  priceEur         Int
  adminNotes       String?
  completedAt      DateTime?
  /// Checkout locale for transactional email (`fi` | `en`).
  locale           String         @default("fi")
  dataMigration    Boolean        @default(false)
  dataMigrationSize String?       // "standard" | "large" when dataMigration is true
  dataMigrationNotes String?      // admin: what was migrated / verification
  /// Optional curated app packs (e.g. local_ai, media_creator) — see lib/billing/app-bundles.ts
  appBundleIds     String[]       @default([])
  /// Optional P2V-style image before Linux install — priced add-on; see lib/billing/portable-vm.ts
  portableVmAddon  Boolean        @default(false)
  portableVmHandoff PortableVmHandoff?
  /// Post-checkout Care interest from wizard (`PLUS` | `PRO`).
  carePackageInterest String?
}

enum PortableVmHandoff {
  CUSTOMER_STORAGE
  SHIPPED_MEDIA
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ServiceTier {
  INSTALL_ONLY
  SSD_BASIC
  SSD_RAM
  FULL_SERVICE
  B2B
}

enum SupportTier {
  FULL
  EMAIL
  DISCORD_ONLY
}

enum DeliveryMethod {
  HOME_PICKUP
  DROP_OFF
  SELF
}

enum HddRemovalOption {
  SPARKKI_REMOVES
  CUSTOMER_REMOVES
  KEEP_IN_DEVICE
}

model UsbOrder {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  status          String   @default("pending")
  customerName    String
  customerEmail   String
  address         String
  stripeSessionId String?
  /// Checkout locale for transactional email (`fi` | `en`).
  locale          String   @default("fi")
}

/// Processed Stripe webhook event ids (idempotency; delete row on handler failure so Stripe can retry).
model StripeProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

/// Imported retail-style laptop listings (reference only — not Sparkki compatibility verdicts).
model LaptopReferenceSpec {
  id                String  @id @default(cuid())
  manufacturer      String
  modelName         String
  category          String?
  screenSize        String?
  screenDetail      String?
  cpu               String?
  ram               String?
  storage           String?
  gpu               String?
  operatingSystem   String?
  osVersion         String?
  weight            String?
  priceEuros        String?

  @@index([manufacturer, modelName])
}

/// Cached SearXNG/LLM laptop spec lookups (per make+model+locale) for faster repeat requests.
model LaptopSpecsInternetCache {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  makeNorm         String
  modelNorm        String
  locale           String
  makeDisplay      String
  modelDisplay     String
  summary          String?
  specUrl          String?
  searxResultCount Int      @default(0)
  usedLlm          Boolean  @default(false)
  expiresAt        DateTime

  @@unique([makeNorm, modelNorm, locale])
  @@index([expiresAt])
  @@index([updatedAt])
}

/// Anonymous compatibility runs from POST /api/compatibility (wizard, /koneet, etc.) for aggregate stats.
model CompatibilityCheck {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  /// "web" | "app" (reserved for Sparkki Checker / future clients)
  source              String   @default("web")
  make                String
  model               String
  ramGb               Int?
  diskType            String?
  status              String
  reasons             Json
  speedGainEstimate   String
  orderId             String?
  convertedToOrder    Boolean  @default(false)

  @@index([createdAt])
}

model ComputerModel {
  id         String           @id @default(cuid())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  make       String
  model      String
  yearFrom   Int?
  yearTo     Int?
  status     ModelCheckStatus @default(UNCHECKED)
  compatible Boolean?
  verdict    String?
  ssdSlot    String?
  maxRamGb   Int?
  notes      String?
  checkedBy  String?
  checkedAt  DateTime?

  @@unique([make, model])
}

enum ModelCheckStatus {
  UNCHECKED
  IN_REVIEW
  APPROVED
  REJECTED
}

model Guide {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  slug       String   @unique
  titleFi    String
  titleEn    String?
  descFi     String
  descEn     String?
  category   String
  difficulty String
  minutesFi  Int
  published  Boolean  @default(false)
  order      Int      @default(0)
  videoUrl   String?
  coverImage String?
}

model AdminUser {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  email        String    @unique
  /// Optional login alias (e.g. "admin") — unique when set; sign-in accepts email or username.
  username     String?   @unique
  name         String?
  passwordHash String
  role         AdminRole @default(EDITOR)
}

/// Append-only log of admin mutations (orders, models, guides, etc.).
model AdminAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  actorEmail String
  action     String
  entity     String
  entityId   String?
  metadata   Json?

  @@index([entity, entityId])
  @@index([createdAt])
}

enum AdminRole {
  SUPER
  EDITOR
}

/// Sparkki Care monthly subscription (FEATURES.md #2) — Stripe Billing.
model CareSubscription {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  customerEmail    String      @unique
  customerName     String
  /// Optional link to original service order.
  orderId          String?
  status           CareStatus  @default(ACTIVE)
  stripeSubId      String      @unique
  stripeCustomerId String?
  currentPeriodEnd DateTime
  cancelledAt      DateTime?
  notes            String?
  /// Checkout locale for transactional email (`fi` | `en`).
  locale           String      @default("fi")
}

enum CareStatus {
  ACTIVE
  CANCELLED
  PAUSED
}
