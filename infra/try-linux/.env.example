# Published HTTP port on the machine running docker compose.
# Upstream host:port for Mint/Fedora websockify is set in nginx/default.conf (default 192.168.2.100:6080 / :6081).
HTTP_PORT=8080

# Optional shared gate (must match Vire NEXT_PUBLIC_TRY_LINUX_ACCESS_TOKEN). Requests need ?access_token=...
# TRY_LINUX_ACCESS_TOKEN=

# With docker-compose.tls.yml — host port for Caddy HTTPS (internal CA by default).
# HTTPS_PORT=8443
