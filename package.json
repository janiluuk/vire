{
  "name": "sparkki",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "cookie": "^0.7.2"
  },
  "scripts": {
    "dev": "next dev -p 1337",
    "build": "prisma generate && next build && mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static .next/standalone/public && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start": "sh -c 'cd .next/standalone && exec node server.js'",
    "lint": "next lint",
    "ci": "bash ./scripts/ci-local.sh",
    "ci:fast": "bash ./scripts/ci-local.sh --fast",
    "ci:quick": "npm run lint && npm run test:unit",
    "ci:act": "act pull_request -j test --container-architecture linux/amd64",
    "test": "npm run test:unit && npm run test:functional",
    "test:unit": "vitest run",
    "test:functional": "vitest run --config vitest.functional.config.ts",
    "test:e2e": "sh -c 'test -f .next/standalone/server.js || npm run build' && playwright test",
    "lh:ci": "lhci autorun --config=./lighthouserc.json",
    "docs:screenshots": "tsx scripts/docs-screenshots.ts",
    "reference:build": "tsx scripts/build-reference-laptops.ts",
    "reference:import": "tsx scripts/import-laptop-reference.ts",
    "docker:build:web": "./scripts/docker-build-web.sh",
    "postinstall": "prisma generate",
    "security:audit": "npm audit",
    "security:audit:prod": "npm audit --omit=dev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "5.22.0",
    "@stripe/stripe-js": "^9.4.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "next-intl": "^4.11.2",
    "next-mdx-remote": "^6.0.0",
    "prisma": "5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.75.0",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.41",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
