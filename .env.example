# Database (Postgres in docker-compose — keep credentials in sync with POSTGRES_*)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="vire"
POSTGRES_PORT="5432"
# Host / Prisma CLI / `npm run dev` when `db` is up (`docker compose up -d`).
# If you change POSTGRES_PORT, use the same port in the host part of this URL.
DATABASE_URL="postgresql://postgres:password@localhost:5432/vire"
# Inside Compose, `web` and `migrate` use hostname `db` (set in docker-compose.yml).

# Auth (NextAuth)
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:1337"

# Stripe (optional for checkout)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Optional Stripe Price IDs (if empty, Checkout uses inline EUR amounts)
STRIPE_PRICE_SSD_BASIC=""
STRIPE_PRICE_SSD_RAM=""
STRIPE_PRICE_FULL_SERVICE=""
STRIPE_PRICE_USB_STICK=""

# Distributed rate limits (optional — when unset, limits are in-memory per Node process)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Set to "true" in production behind HTTPS to send Strict-Transport-Security (see next.config.mjs)
# ENABLE_HSTS="true"

# JSON logs on API routes in development too (production always uses JSON). See docs/operations.md.
# STRUCTURED_LOG="1"

# Wizard E2E (`e2e/wizard-order.spec.ts`) fills make/model and contact fields in the spec (no env flag).

# Staging: emit Content-Security-Policy-Report-Only (see docs/operations.md). Does not block resources.
# ENABLE_CSP_REPORT_ONLY="true"

# Email (optional)
RESEND_API_KEY=""
RESEND_FROM="Vire <onboarding@resend.dev>"
# Inbound address for B2B quote form (server-only; Resend sends here)
B2B_QUOTE_NOTIFY_EMAIL=""
# Inbound address for /tuki contact form (server-only; Resend sends here)
SUPPORT_NOTIFY_EMAIL=""

# Public embeds (optional)
# Calendly “inline embed” full URL for iframe src — shows booking block on /tuki
# NEXT_PUBLIC_CALENDLY_EMBED_URL="https://calendly.com/your-user/30min?embed_domain=..."
# Discord Server ID for widget on /yhteiso (numeric ID from Discord app → Server ID)
# NEXT_PUBLIC_DISCORD_WIDGET_GUILD_ID=""
NEXT_PUBLIC_SITE_URL="http://localhost:1337"
# Host port for the `web` service (container still listens on 3000)
APP_PORT="1337"
# Browser try-Linux (noVNC) — base URL of infra/try-linux nginx proxy; leave empty to hide demo cards
# Example: http://127.0.0.1:8080 (see infra/try-linux/README.md)
NEXT_PUBLIC_TRY_LINUX_PROXY_BASE=""
# Same value as infra/try-linux TRY_LINUX_ACCESS_TOKEN when gate is enabled (public; lab-only).
# NEXT_PUBLIC_TRY_LINUX_ACCESS_TOKEN=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_DISCORD_INVITE=""
# Public YouTube channel URL — when set, home, footer, and community show a link
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=""

# Laptop spec lookup (server-side only; wizard, order tracking, admin order detail).
# Uses SearXNG JSON API + optional local LLM (OpenAI-compatible /v1/chat/completions or Ollama /api/chat).
# LAN / Docker reachability: apps/vire-checker/README.md § "Laptop spec / AI lookup (LAN)".
# SearXNG JSON API base (no trailing slash). Required for web spec search; leave empty to disable.
SPECS_SEARXNG_BASE_URL=""
# OpenAI-compatible or Ollama base URL, reachable from the Node process (e.g. http://127.0.0.1:11434).
SPECS_AI_BASE_URL=""
SPECS_AI_MODEL="llama3"
# openai | ollama | auto
SPECS_AI_KIND="auto"
# SPECS_AI_API_KEY=""   # optional Bearer for OpenAI-compatible gateways
# SPECS_LOOKUP_ENABLED="false"   # set to disable all lookups

# Admin seed
ADMIN_EMAIL="admin@vire.fi"
ADMIN_PASSWORD="changeme"
