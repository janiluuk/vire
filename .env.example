# Local configuration — copy to `.env` in the project root and fill in values.
# `.env` is gitignored; this file must stay free of real secrets or production credentials.
#
# Docker Compose reads `.env` for ${VAR} substitution. Next.js loads `.env` then `.env.local`
# (`.env.local` overrides).

# Database (keep POSTGRES_* aligned with DATABASE_URL when using Compose + host Prisma)
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB="sparkki"
POSTGRES_PORT="5432"
# Optional: override DB URL used only during `docker compose build web` (Prisma at `next build`).
# If unset, compose defaults to postgresql://POSTGRES_USER:POSTGRES_PASSWORD@host.docker.internal:POSTGRES_PORT/POSTGRES_DB
# DATABASE_URL_BUILD=""
# Prisma / Next.js, e.g. postgresql://USER:PASSWORD@localhost:5432/sparkki
DATABASE_URL=""

# Auth (NextAuth) — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:1337"

# Stripe (optional for checkout)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Optional Stripe Price IDs (if empty, Checkout uses inline EUR amounts)
STRIPE_PRICE_SSD_BASIC=""
STRIPE_PRICE_SSD_RAM=""
STRIPE_PRICE_FULL_SERVICE=""
STRIPE_PRICE_USB_STICK=""

# Distributed rate limits (optional — when unset, limits are in-memory per Node process)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Set to "true" in production behind HTTPS to send Strict-Transport-Security (see next.config.mjs)
# ENABLE_HSTS="true"

# JSON logs on API routes in development too (production always uses JSON). See docs/operations.md.
# STRUCTURED_LOG="1"

# Staging: emit Content-Security-Policy-Report-Only (see docs/operations.md). Does not block resources.
# ENABLE_CSP_REPORT_ONLY="true"
# Production rollout: enforcing CSP (see docs/operations.md).
# ENABLE_CSP_ENFORCE="true"
# Optional: override origin used in CSP report-uri (defaults to NEXT_PUBLIC_SITE_URL). See docs/operations.md.
# CSP_REPORT_BASE_URL="https://sparkki.example.com"

# Email (optional)
RESEND_API_KEY=""
RESEND_FROM=""
# Sparkki for Good application emails (Phase 23 — prefer SPARKKI_*; VIRE_* still works)
SPARKKI_FOR_GOOD_NOTIFY_EMAIL=""
VIRE_FOR_GOOD_NOTIFY_EMAIL=""

# Public embeds (optional)
# Scheduling link only (https://calendly.com/...). embed_domain / embed_type are added automatically from NEXT_PUBLIC_SITE_URL.
# NEXT_PUBLIC_CALENDLY_EMBED_URL="https://calendly.com/your-user/30min"
# Optional: override hostname sent to Calendly if it differs from NEXT_PUBLIC_SITE_URL (proxy, preview URL).
# NEXT_PUBLIC_CALENDLY_EMBED_DOMAIN="sparkki.dudeisland.eu"
# NEXT_PUBLIC_DISCORD_WIDGET_GUILD_ID=""
NEXT_PUBLIC_SITE_URL="http://localhost:1337"
APP_PORT="1337"
# Browser try-Linux (noVNC) — base URL of infra/try-linux nginx proxy; leave empty to hide demo cards
NEXT_PUBLIC_TRY_LINUX_PROXY_BASE=""
# NEXT_PUBLIC_TRY_LINUX_ACCESS_TOKEN=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_DISCORD_INVITE=""
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=""

# Laptop spec lookup (server-side only) — see docs/model-search.md
# SearXNG: base URL only, no trailing slash; Sparkki calls GET {base}/search?format=json
# SPECS_SEARXNG_BASE_URL="https://search.dudeisland.eu"
# Ollama on LAN: must be reachable from the Node process (not the browser)
SPECS_AI_BASE_URL="http://192.168.2.101:11434"
SPECS_AI_MODEL="qwen3.5:9b"
SPECS_AI_KIND="ollama"
SPECS_SEARXNG_BASE_URL="https://search.dudeisland.eu"
#SPECS_AI_BASE_URL=""
#SPECS_AI_MODEL="llama3"
SPECS_AI_KIND="auto"
# SPECS_AI_API_KEY=""
# SPECS_LOOKUP_ENABLED="false"
# SPECS_CACHE_TTL_DAYS="30"
# SPECS_CACHE_EMPTY_TTL_HOURS="24"

# Admin seed (prisma db seed)
ADMIN_EMAIL=""
# Optional login alias (default: admin). Sign-in accepts this or ADMIN_EMAIL.
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
